# Airtable (for events, join form, RSVPs)
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_base_id

# Airtable Website Images (optional - separate base for site images)
# If set, images load from Airtable instead of /public. Table "Images" with columns: Name, Image (attachment)
AIRTABLE_IMAGES_BASE_ID=your_images_base_id

# Anthropic (for LTA chatbot)
ANTHROPIC_API_KEY=your_anthropic_api_key
